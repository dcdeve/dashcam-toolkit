{
  "name": "dashcam-toolkit",
  "version": "0.1.0",
  "description": "Cross-platform dashcam video processor — CLI & desktop app",
  "type": "module",
  "main": "out/main/index.js",
  "bin": {
    "dashcam": "./dist/cli/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "build:electron": "electron-vite build",
    "dev": "electron-vite dev",
    "dev:cli": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'"
  },
  "keywords": [
    "dashcam",
    "video",
    "ffmpeg",
    "concatenate",
    "lossless"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "changelogen": "^0.6.2",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
