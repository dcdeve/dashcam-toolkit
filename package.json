{
  "name": "dashcam-toolkit",
  "version": "0.1.0",
  "description": "Cross-platform dashcam video processor — CLI & desktop app",
  "type": "module",
  "bin": {
    "dashcam": "./dist/cli/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "dashcam",
    "video",
    "ffmpeg",
    "concatenate",
    "lossless"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "changelogen": "^0.6.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
